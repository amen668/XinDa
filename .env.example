# Copy to `.env` and fill in your own values. .env is gitignored.

# DashScope API key (https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=sk-your-key-here

# Override DashScope OpenAI-compatible endpoint if needed
# DASHSCOPE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/arxiv_translation_hub

# LaTeXML binaries (if not on PATH)
# LATEXMLC_PATH=/path/to/latexmlc
# LATEXMLPOST_PATH=/path/to/latexmlpost

# DashScope coding-plan endpoint (good model qwen3.7-plus); separate key/quota
DASHSCOPE_CODING_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_CODING_API_KEY=
